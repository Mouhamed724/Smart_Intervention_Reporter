# 1. Dossiers de dépendances (Se règlent avec npm install, ils font 500Mo, on ne les met JAMAIS sur Github)
node_modules/
backend/node_modules/
frontend/node_modules/

# 2. Fichiers secrets (CONTIENT TON MOT DE PASSE BDD ET TA CLE API - TRÈS DANGEREUX SI PUBLIÉ)
.env
backend/.env

# 3. Fichiers uploadés par les utilisateurs (Photos, audios, PDF générés - ça n'a rien à faire sur Github)
backend/uploads/
uploads/

# 4. Dossiers de compilation (Le résultat du build React, inutile sur Github)
frontend/dist/
frontend/build/

# 5. Fichiers systèmes de ton ordinateur (À cacher pour faire propre)
.DS_Store
Thumbs.db
.vscode/
.idea/